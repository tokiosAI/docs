{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Tokios",
  "colors": {
    "primary": "#F2A23C",
    "light": "#F2A23C",
    "dark": "#E0892A"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 600
    },
    "body": {
      "family": "IBM Plex Sans",
      "weight": 400
    }
  },
  "background": {
    "color": {
      "light": "#F4F5F7",
      "dark": "#0E1116"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "css-variables"
      }
    }
  },
  "favicon": {
    "light": "/images/tokios-icon.svg",
    "dark": "/images/tokios-icon.svg"
  },
  "logo": {
    "light": "/images/tokios-logo-onlight.svg",
    "dark": "/images/tokios-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://tokios.com/contactus"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign Up Free",
      "href": "https://tokios.com/signup"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "quickstart",
              "how-it-works"
            ]
          },
          {
            "group": "Setup",
            "pages": [
              "setup/connector-install",
              "setup/supported-backends",
              "setup/register-model",
              "setup/api-keys"
            ]
          },
          {
            "group": "Using Tokios",
            "pages": [
              "guides/claude-code",
              "guides/openai-codex",
              "guides/compatible-clients",
              "guides/model-routing"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/api-endpoints",
              "reference/connector-config",
              "reference/faq"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/TokiosAI"
    }
  },
  "description": "Tokios Documentation"
}
